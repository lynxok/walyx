datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  logoUrl         String?
  bannerUrl       String?
  themeSettings   String           @default("{\"primaryColor\":\"#f59e0b\",\"backgroundColor\":\"#09090b\",\"layoutMode\":\"grid\",\"textColor\":\"#ffffff\",\"fontFamily\":\"Outfit\",\"cardStyle\":\"glass\"}")
  categories      Category[]
  products        Product[]
  customers       Customer[]
  orders          Order[]
  weeklyMenus     WeeklyMenu[]
  sizeCharts      SizeChart[]
  clothingBrands  ClothingBrand[]
  clothingTypes   ClothingType[]
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  slug        String
  type        String    // "ROPA", "VIANDA", "PASTELERIA"
  price       Float?
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([slug, tenantId])
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int         @default(0)
  imageUrl    String?
  isActive    Boolean     @default(true)
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  weeklyMenuDays WeeklyMenuDay[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Clothing attributes
  size        String?
  color       String?
  material    String?

  // Food / Viandas attributes
  calories     Float?
  ingredients  String?    // comma-separated or text
  isVegan      Boolean    @default(false)
  isGlutenFree Boolean    @default(false)

  // Pastries / Pasteleria attributes
  sweetnessLevel String?  // e.g., "Bajo", "Medio", "Alto"
  portions       Int?     // Number of portions/slices
}

model GlobalUser {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  customers    Customer[]
}

model Customer {
  id           String      @id @default(uuid())
  name         String
  email        String
  phone        String?
  address      String?
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders       Order[]
  globalUserId String?
  globalUser   GlobalUser? @relation(fields: [globalUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([email, tenantId])
}

model Order {
  id              String      @id @default(uuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status          String      @default("PENDING") // PENDING, PREPARING, DELIVERED, CANCELLED
  total           Float
  paymentMethod   String      @default("CASH") // CASH, TRANSFER, CARD
  paymentStatus   String      @default("PENDING") // PENDING, PAID, REFUNDED
  deliveryAddress String?
  deliveryNotes   String?
  deliveryCost    Float?      @default(0)
  deliveryZoneName String?
  deliveryDate     String?
  deliveryTimeSlot String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  price        Float
  variantTitle String?
  customization String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WeeklyMenu {
  id        String          @id @default(uuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startDate DateTime
  days      WeeklyMenuDay[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([tenantId, startDate])
}

model WeeklyMenuDay {
  id          String     @id @default(uuid())
  menuId      String
  menu        WeeklyMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dayName     String     // "Lunes", "Martes", etc.
  productId   String?
  product     Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  limit       Int        @default(30)
  isClosed    Boolean    @default(false)
  holidayName String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([menuId, dayName])
}

// ─── Tablas de Talles (para rubro ROPA) ─────────────────────────────────────

model ClothingBrand {
  id        String      @id @default(uuid())
  name      String
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  charts    SizeChart[]
  createdAt DateTime    @default(now())

  @@unique([tenantId, name])
}

model ClothingType {
  id        String      @id @default(uuid())
  name      String
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  charts    SizeChart[]
  createdAt DateTime    @default(now())

  @@unique([tenantId, name])
}

model SizeChart {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brandId         String
  brand           ClothingBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  clothingTypeId  String
  clothingType    ClothingType  @relation(fields: [clothingTypeId], references: [id], onDelete: Cascade)
  columns         String        // JSON: ["Talle","Pecho (cm)","Largo (cm)"]
  rows            SizeChartRow[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([tenantId, brandId, clothingTypeId])
}

model SizeChartRow {
  id          String    @id @default(uuid())
  chartId     String
  chart       SizeChart @relation(fields: [chartId], references: [id], onDelete: Cascade)
  values      String    // JSON: ["S","88-92","68"]
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
}
