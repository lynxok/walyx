# =============================================================
# Walyx - Variables de Entorno (EJEMPLO - NO subir con valores reales)
# =============================================================

# Base de datos Neon PostgreSQL (Serverless)
# Con connection pooling para entornos serverless (Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&connection_limit=1"

# URL directa (sin pooling) para migraciones de Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Clave secreta para firmar cookies de sesión (genera con: openssl rand -hex 32)
SESSION_SECRET="change_me_with_a_secure_random_string_min_32_chars"

# Resend API Key para emails OTP (opcional - sin esto, el OTP se imprime en consola)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# URL pública de la app (cambiar en producción)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
